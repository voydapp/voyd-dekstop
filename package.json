{
  "name": "voyd-desktop",
  "version": "1.0.54",
  "description": "VOYD Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.voyd.desktop",
    "productName": "VOYD",
    "compression": "maximum",
    "files": [
      "main.js",
      "preload.js",
      "app-update.yml",
      "assets/**",
      "node_modules/**",
      "!node_modules/**/test/**",
      "!node_modules/**/*.md",
      "!node_modules/**/LICENSE",
      "!node_modules/**/*.map"
    ],
    "extraResources": [
      {
        "from": "app-update.yml",
        "to": "app-update.yml"
      }
    ],
    "directories": {
      "output": "dist16"
    },
    "publish": {
      "provider": "github",
      "owner": "voydapp",
      "repo": "voyd-dekstop",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "keywords": [],
  "author": "voydapp",
  "license": "ISC",
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "electron-updater": "^6.3.9"
  }
}
