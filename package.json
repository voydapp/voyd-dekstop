{
  "name": "voyd-desktop",
  "version": "1.0.15",
  "description": "VOYD Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.voyd.desktop",
    "productName": "VOYD",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "voydapp",
      "repo": "voyd-dekstop",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "keywords": [],
  "author": "voydapp",
  "license": "ISC",
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  }
}
